# ManfacterCAD — Environment Variables
# Copia este archivo a .env.local y completa los valores

# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/manfactercad"

# LLM Provider: "gemini" o "deepseek"
LLM_PROVIDER=gemini

# Gemini (Google AI) — gratuito, multimodal
GOOGLE_GENERATIVE_AI_API_KEY=

# DeepSeek v4 vía OpenCode — solo texto
OPENCODE_API_KEY=

# NextAuth
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
