# ── ManfacterCAD ──
# Copia este archivo como .env y rellena tus valores.
# Para desarrollo local: no hace falta .env, los defaults ya apuntan a 127.0.0.1

# ── Backend (Python servers) ──
# Host al que se bindean los 3 servidores. "127.0.0.1" para local, "0.0.0.0" para VPS
BACKEND_HOST=127.0.0.1

# Puertos (solo cambiar si hay conflictos)
# BACKEND_PORT=8000
# GEMINI_AGENT_PORT=8002
# OPENAI_AGENT_PORT=8003

# ── API Keys (obligatorias) ──
GOOGLE_GENERATIVE_AI_API_KEY=
OPENCODE_API_KEY=
OPENAI_API_KEY=

# ── Frontend (Next.js) ──
# Solo necesario en Vercel. En local se usa 127.0.0.1 automáticamente.
# NEXT_PUBLIC_BACKEND_HOST=127.0.0.1
